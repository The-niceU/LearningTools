/**index.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}
.swiper{
  width: 100%;
  height: 340rpx;
}
.swiper image{
  width: 100%;
  height: 100%;
}
.banner{
  background: #0B3B87;
  color: #fff;
  padding: 30px 20px;
  text-align: center;
  font-size: 24px;
  font-weight: 600;
}
.menu{
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.item{
  width: 47%;
  background: #f8f9fa;
  padding: 25px 0;
  margin-bottom: 12px;
  border-radius: 8px;
  text-align: center;
  font-size: 16px;
  color: #333;
}
.item text{
  margin: 6rpx 0;
}
.notice{
  padding: 8px 0;
  color: #666;
  border-bottom: 1px solid #eee;
}