.canteen{padding:10px 0;border-bottom:1px solid #eee;}
.canteen .name{font-weight:600;color:#0B3B87;}
.canteen .time{font-size:12px;color:#666;margin:4px 0;}
.canteen .food{color:#333;}
.express{padding:10px 0;border-bottom:1px solid #eee;}
.express .name{font-weight:600;}
.express .address{font-size:12px;color:#666;margin-top:4px;}
.lost .item{padding:8px 0;border-bottom:1px solid #eee;color:#333;}
.add-btn{
  background: #0B3B87;
  color: #fff;
  border-radius: 8px;
  margin-top:10px;
  padding:10px 0;
  text-align: center;
}
.item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.info {
  flex: 1;
}
.info view {
  margin: 6rpx 0;
  line-height: 1.5;
}
.title-sm {
  font-size: 28rpx;
  font-weight: 500;
  margin: 16rpx 0;
}