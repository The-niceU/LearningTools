/* pages/tool/tool.wxss */
.box{padding:15px;}
.kebiao{background:white; border-radius:8px; padding:10px;}
.row{padding:12px; border-bottom:1px solid #eee;}

.schedule .day{font-weight:600;color:#0B3B87;margin:8px 0;}
.schedule .course{padding:6px 0;color:#333;}
.empty-room{padding:8px 0;border-bottom:1px solid #eee;color:#333;}
.phone{padding:10px 0;border-bottom:1px solid #eee;}
.phone .name{font-weight:600;}
.phone .num{color:#0B3B87;margin-top:4px;}

/* 校园工具页面整体样式 */
.tool-container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 工具标题 */
.tool-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin: 30rpx 0;
  padding-left: 10rpx;
  border-left: 8rpx solid #0052d9;
}

/* 工具卡片列表 */
.tool-card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 工具卡片核心样式 */
.tool-card {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s ease;
}

/* 点击动效 */
.tool-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

/* 卡片图标 */
.card-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #e8f3ff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.card-icon image {
  width: 48rpx;
  height: 48rpx;
}

/* 卡片内容 */
.card-content {
  flex: 1;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

/* 卡片箭头 */
.card-arrow {
  font-size: 28rpx;
  color: #999;
  margin-left: 10rpx;
}