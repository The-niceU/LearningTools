/**app.wxss**/
page{
  background: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
}
.container{
  padding: 0;
  margin: 0;
}
.card{
  background: #fff;
  border-radius: 12px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  margin: 10px 15px;
  padding: 15px;
}
.title{
  font-size: 18px;
  font-weight: 600;
  color: #0B3B87;
  margin-bottom: 12px;
}